# Copy to .env and fill in. Paper and live keys are separate on purpose:
# live keys should not exist in this file until you are ready for live mode.
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

ALPACA_PAPER_URL=https://paper-api.alpaca.markets/v2
ALPACA_LIVE_URL=https://api.alpaca.markets

ANTHROPIC_API_KEY=
# Optional: Reddit sentiment (praw) — milestone 3
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Optional: Discord webhook for daily summaries / approval pings
DISCORD_WEBHOOK_URL=


